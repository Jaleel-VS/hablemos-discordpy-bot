# Activity backend (FastAPI) — copy to backend/.env for local dev, or set as
# Railway service variables in production.

# From the Discord Developer Portal (your existing Hablemos application).
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret

# Optional
PORT=8080
ENVIRONMENT=development

# Frontend (Vite) — needed at BUILD time. For local `npm run dev` put this in
# frontend/.env; in production it is passed as the VITE_DISCORD_CLIENT_ID
# Docker build arg (see Dockerfile).
VITE_DISCORD_CLIENT_ID=your_application_client_id

# Local dev only: where the Vite dev server proxies /api and /.proxy/api.
VITE_API_TARGET=http://localhost:8080
